# Path to your Firebase service account JSON key file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Firebase project ID (should match your firebase.json / .firebaserc)
FIREBASE_PROJECT_ID=bluemind-landing

# Delay between requests in milliseconds (default: 1500)
# Increase this to be more polite to the target server
SCRAPE_DELAY_MS=1500
